#!/usr/bin/env lua5.4

local dir = debug.getinfo(1).source:match("@(.*/)")
package.path = dir .. "?.lua;" .. package.path

local argparse = require "argparse"

local function exec (cmd)
    local ok, _, code = os.execute(cmd)
    if not ok then
        io.stderr:write(
            "ERROR: command failed ("
                .. tostring(code) .. "): " .. cmd .. "\n"
        )
        os.exit(1)
    end
end

local function popen (cmd)
    local h = io.popen(cmd)
    local out = h:read("a"):match("^%s*(.-)%s*$")
    h:close()
    return out
end

local parser = argparse("freechains", "Freechains VCS")
parser:option("--root"):default(
    os.getenv("HOME") .. "/.freechains/"
)

local chains = parser:command("chains")
local add = chains:command("add")
add:argument("alias")
local lua_cmd = add:command("lua")
lua_cmd:argument("file")

local args = parser:parse()

if args.lua then
    local genesis = dofile(args.file)
    if type(genesis) ~= "table" then
        io.stderr:write(
            "ERROR: file must return a table\n"
        )
        os.exit(1)
    end

    local root = args.root
    local chains_dir = root .. "chains/"
    local tmp = chains_dir .. "tmp-" .. os.time()

    exec("git init " .. tmp)
    exec("cp " .. args.file .. " "
        .. tmp .. "/.genesis.lua")
    exec("git -C " .. tmp .. " add .genesis.lua")
    exec("git -C " .. tmp
        .. ' -c user.name="" -c user.email=""'
        .. ' commit --allow-empty-message -m ""')

    local hash = popen(
        "git -C " .. tmp .. " rev-parse HEAD"
    )

    local final = chains_dir .. hash
    os.rename(tmp, final)
    exec("ln -s " .. hash .. "/ "
        .. chains_dir .. args.alias)

    print(hash)
end
