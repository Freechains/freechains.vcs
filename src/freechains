#!/usr/bin/env lua5.4

local VERSION = "v0.20"

local argparse = require "argparse"
local common   = require "common"

local parser = argparse()

parser
    :name "freechains"
    :description "Freechains: Permissionless Peer-to-peer Content Dissemination"
    :epilog [[
For more information, please visit our website:

    https://www.freechains.org/
]]

parser
    :flag("-v --version", "Show version.")
    :action(function()
        print("freechains " .. VERSION)
        os.exit(0)
    end)

parser
    :option("--root")
    :default(os.getenv("HOME") .. "/.freechains/")

local cmd = {
    chains = {
        _ = parser:command("chains"),
        add = {
            dir = {},
        },
        rem = {},
        dir = {},
    },
    chain = {
        _ = parser:command("chain"),
        post = {
            file = {},
            inline = {},
        },
        like = {},
    },
}

-- cmd.chains
do
    -- cmd.chains.add
    cmd.chains.add._ = cmd.chains._:command("add")
    do
        -- cmd.chains.add.lua
        cmd.chains.add._:argument("alias")
        cmd.chains.add.dir._ = cmd.chains.add._:command("dir")
        cmd.chains.add.dir._:argument("path")
    end

    -- cmd.chains.rem
    cmd.chains.rem._ = cmd.chains._:command("rem")
    cmd.chains.rem._:argument("alias")

    -- cmd.chains.dir
    cmd.chains.dir._ = cmd.chains._:command("dir")
end

-- cmd.chain
do
    cmd.chain._:argument("alias")

    -- cmd.chain.post
    cmd.chain.post._ = cmd.chain._:command("post")
    cmd.chain.post._:option("--sign")
    cmd.chain.post._:option("--why")
    do
        -- cmd.chain.post.file
        cmd.chain.post.file._ = cmd.chain.post._:command("file")
        cmd.chain.post.file._:argument("path")

        -- cmd.chain.post.inline
        cmd.chain.post.inline._ = cmd.chain.post._:command("inline")
        cmd.chain.post.inline._:argument("text")
        cmd.chain.post.inline._:option("--file")
    end

    -- cmd.chain.like
    cmd.chain.like._ = cmd.chain._:command("like")
    cmd.chain.like._:argument("number")
    cmd.chain.like._:argument("hash")
    cmd.chain.like._:option("--sign")
    cmd.chain.like._:option("--why")
end

local args = parser:parse()

if args.chains then
    local chains = args.root .. "/chains/"
    if args.add then
        if args.dir then
            local genesis = dofile(args.path .. "/genesis.lua")
            if type(genesis) ~= "table" then
                ERROR("chains add : file must return a table")
            end

            if io.open(chains.."/"..args.alias) then
                ERROR("chains add : alias already exists: " .. args.alias)
            end

            local tmp
            local t = os.time()
            while true do
                tmp = chains .. "/tmp-" .. t .. "/"
                if not io.open(tmp .. ".") then
                    break
                end
                t = t + 1
            end

            exec ("chains add : git init failed",
                "git init " .. tmp
            )
            git_config(tmp)
            exec ("chains add : mkdir failed",
                "mkdir -p " .. tmp .. "/.freechains"
            )
            exec ("chains add : copy genesis failed",
                "cp -r " .. args.path .. "/* " .. tmp .. "/.freechains/"
            )
            exec ("chains add : git add failed",
                "git -C " .. tmp .. " add .freechains/"
            )
            exec("chains add : git commit failed",
                "git -C " .. tmp .. ' commit --allow-empty-message -m ""'
            )

            local hash = exec ("chains add : git rev-parse failed",
                "git -C " .. tmp .. " rev-parse HEAD"
            )

            local final = chains .. "/" .. hash
            if not os.rename(tmp, final) then
                assert(exec("rm -rf " .. tmp))
                ERROR("chains add : chain already exists: " .. hash)
            end
            exec ("chains add : symlink failed",
                "ln -s " .. hash .. "/ " .. chains .. "/" .. args.alias
            )

            print(hash)
        end
    elseif args.rem then
        local alias = chains .. "/" .. args.alias
        local lnk = exec ("chains rem : not found: " .. args.alias,
            "readlink " .. alias
        )
        exec ("chains rem : remove failed",
            "rm -rf " .. chains .. lnk
        )
        os.remove(alias)
    elseif args.dir then
        local out = exec ("chains dir : list failed",
            "find " .. chains .. " -maxdepth 1 -type l -printf '%f\\n' | sort"
        )
        io.write(out)
    end
elseif args.chain then
    local repo = args.root .. "/chains/" .. args.alias .. "/"
    local name

    if args.post then
        if args.inline then     -- before ambiguous args.file
            local text = args.text
            if not text:match("\n$") then
                text = text .. "\n"
            end

            if args.file then   -- ambiguous with post file
                name = args.file
                local f = io.open(repo .. args.file, "a")   -- appends
                f:write(text)
                f:close()
            else
                local hash = exec ("chain post : git hash-object failed",
                    "printf '%s' '" .. text .. "' | git hash-object --stdin"
                )
                name = os.time() .. "-" .. hash:sub(1,8) .. ".txt"
                local f = io.open(repo .. name, "w")        -- truncates
                f:write(text)
                f:close()
            end
        elseif args.file then   -- after args.inline
            name = args.path:match("[^/]+$")
            exec ("chain post : copy failed: " .. args.path,
                "cp " .. args.path .. " " .. repo .. "/"
            )
        end

        exec ("chain post : git add failed",
            "git -C " .. repo .. " add " .. name
        )

        local s1, s2 = "", ""
        if args.sign then
            s1 = " -c user.signingkey=" .. args.sign
                .. " -c gpg.format=openpgp"
            s2 = " -S"
        end

        local msg = args.why or ""
        exec ("chain post : git commit failed",
            "git -C " .. repo .. s1 .. " commit" .. s2
                .. " --allow-empty-message -m '" .. msg .. "'"
        )

        local hash = exec ("chain post : git rev-parse failed",
            "git -C " .. repo .. " rev-parse HEAD"
        )
        print(hash)
    elseif args.like then
        if not args.sign then
            io.stderr:write("ERROR: --sign is required for like\n")
            os.exit(1)
        end

        if not args.number:match("^[%+%-]%d+$") then
            io.stderr:write("ERROR: number must start with + or -\n")
            os.exit(1)
        end

        -- validate target exists
        local h = io.popen (
            "git -C " .. repo .. " cat-file -t " .. args.hash
            .. " 2>/dev/null"
        )
        local typ = h:read("a"):match("^(%S+)")
        h:close()
        if typ ~= "commit" then
            io.stderr:write("ERROR: target not found: " .. args.hash .. "\n")
            os.exit(1)
        end

        -- self-like check (positive only)
        if tonumber(args.number) > 0 then
            local author = exec (
                "git -C " .. repo .. " log -1 --format=%GK " .. args.hash
            )
            if author == args.sign then
                io.stderr:write("ERROR: cannot like own post\n")
                os.exit(1)
            end
        end

        local tree = "4b825dc642cb6eb9a060e54bf899d69ff964f6d9"
        local parent = exec("git -C " .. repo .. " rev-parse HEAD")
        local msg = args.why or ""
        local s1 = " -c user.signingkey=" .. args.sign
            .. " -c gpg.format=openpgp"
        local commit = exec (
            "git -C " .. repo .. s1
            .. " commit-tree " .. tree .. " -p " .. parent .. " -S"
            .. " --trailer 'freechains-like: " .. args.number
            .. " " .. args.hash .. "'"
            .. " -m '" .. msg .. "'"
        )
        exec("git -C " .. repo .. " reset --hard " .. commit)
        print(commit)
    end
end
