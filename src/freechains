#!/usr/bin/env lua5.4

local VERSION = "v0.20"

local argparse = require "argparse"

function exec (cmd, stderr)
    local redir = stderr and "&2" or "/dev/null"
    local h = io.popen(cmd .. " 2>" .. redir)
    local raw = h:read("a")
    local out = raw:match("^([^\n]*)\n$") or raw
    local ok, _, code = h:close()
    if not ok then
        io.stderr:write (
            "ERROR [" .. tostring(code) .. "]: " .. cmd .. "\n"
        )
        os.exit(1)
    end
    return out, 0
end

local parser = argparse()

parser
    :name "freechains"
    :description "Freechains: Permissionless Peer-to-peer Content Dissemination"
    :epilog [[
For more information, please visit our website:

    https://www.freechains.org/
]]

parser
    :flag("-v --version", "Show version.")
    :action(function()
        print("freechains " .. VERSION)
        os.exit(0)
    end)

parser
    :option("--root")
    :default(os.getenv("HOME") .. "/.freechains/")

local cmd = {
    chains = {
        _ = parser:command("chains"),
        add = {
            lua = {},
        },
        rem = {},
        dir = {},
    },
    chain = {
        _ = parser:command("chain"),
        post = {
            file = {},
            inline = {},
        },
    },
}

-- cmd.chains
do
    -- cmd.chains.add
    cmd.chains.add._ = cmd.chains._:command("add")
    do
        -- cmd.chains.add.lua
        cmd.chains.add._:argument("alias")
        cmd.chains.add.lua._ = cmd.chains.add._:command("lua")
        cmd.chains.add.lua._:argument("path")
    end

    -- cmd.chains.rem
    cmd.chains.rem._ = cmd.chains._:command("rem")
    cmd.chains.rem._:argument("alias")

    -- cmd.chains.dir
    cmd.chains.dir._ = cmd.chains._:command("dir")
end

-- cmd.chain
do
    cmd.chain._:argument("alias")

    -- cmd.chain.post
    cmd.chain.post._ = cmd.chain._:command("post")
    cmd.chain.post._:option("--sign")
    do
        -- cmd.chain.post.file
        cmd.chain.post.file._ = cmd.chain.post._:command("file")
        cmd.chain.post.file._:argument("path")

        -- cmd.chain.post.inline
        cmd.chain.post.inline._ = cmd.chain.post._:command("inline")
        cmd.chain.post.inline._:argument("text")
        cmd.chain.post.inline._:option("--file")
    end
end

local args = parser:parse()

if args.chains then
    local chains = args.root .. "/chains/"
    if args.add then
        if args.lua then
            local genesis = dofile(args.path)
            if type(genesis) ~= "table" then
                io.stderr:write("ERROR: file must return a table\n")
                os.exit(1)
            end

            if io.open(chains.."/"..args.alias) then
                io.stderr:write (
                    "ERROR: alias already exists: " .. args.alias .. "\n"
                )
                os.exit(1)
            end

            local tmp
            local t = os.time()
            while true do
                tmp = chains .. "/tmp-" .. t .. "/"
                if not io.open(tmp .. ".") then
                    break
                end
                t = t + 1
            end

            exec("git init " .. tmp)
            exec("cp " .. args.path .. " " .. tmp .. "/.genesis.lua")
            exec("git -C " .. tmp .. " add .genesis.lua")
            exec("git -C " .. tmp
                .. ' -c user.name="-" -c user.email="-"'
                .. ' commit --allow-empty-message -m ""')

            local hash = exec("git -C " .. tmp .. " rev-parse HEAD")

            local final = chains .. "/" .. hash
            if not os.rename(tmp, final) then
                exec("rm -rf " .. tmp)
                io.stderr:write (
                    "ERROR: chain already exists: " .. hash .. "\n"
                )
                os.exit(1)
            end
            exec("ln -s " .. hash .. "/ " .. chains .. "/" .. args.alias)

            print(hash)
        end
    elseif args.rem then
        local alias = chains .. "/" .. args.alias
        local lnk = exec("readlink " .. alias)
        exec("rm -rf " .. chains .. lnk)
        os.remove(alias)
    elseif args.dir then
        local out = exec (
            "find " .. chains .. " -maxdepth 1 -type l -printf '%f\\n' | sort"
        )
        io.write(out)
    end
elseif args.chain then
    local repo = args.root .. "/chains/" .. args.alias .. "/"
    local name

    if args.post then
        if args.inline then     -- before ambiguous args.file
            local text = args.text
            if not text:match("\n$") then
                text = text .. "\n"
            end

            if args.file then   -- ambiguous with post file
                name = args.file
                local f = io.open(repo .. args.file, "a")   -- appends
                f:write(text)
                f:close()
            else
                local hash = exec (
                    "printf '%s' '" .. text .. "' | git hash-object --stdin"
                )
                name = os.time() .. "-" .. hash:sub(1,8) .. ".txt"
                local f = io.open(repo .. name, "w")        -- truncates
                f:write(text)
                f:close()
            end
        elseif args.file then   -- after args.inline
            name = args.path:match("[^/]+$")
            exec("cp " .. args.path .. " " .. repo .. "/")
        end

        exec("git -C " .. repo .. " add " .. name)

        local s1, s2 = "", ""
        if args.sign then
            s1 = " -c user.signingkey=" .. args.sign .. " -c gpg.format=openpgp"
            s2 = " -S"
        end

        exec("git -C " .. repo
            .. ' -c user.name="-" -c user.email="-"'
            .. s1 .. ' commit' .. s2
            .. ' --allow-empty-message -m ""')

        local hash = exec("git -C " .. repo .. " rev-parse HEAD")
        print(hash)
    end
end
