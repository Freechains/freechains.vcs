#!/usr/bin/env lua5.4

local VERSION = "v0.20"

local argparse = require "argparse"

function exec (cmd)
    local h = io.popen(cmd .. " 2>&1")
    local out = h:read("a"):match("^%s*(.-)%s*$")
    local ok, _, code = h:close()
    if not ok then
        io.stderr:write (
            "ERROR [" .. tostring(code) .. "]: " .. cmd .. "\n"
        )
        os.exit(1)
    end
    return out, 0
end

local parser = argparse()

parser
    :name "freechains"
    :description "Freechains: Permissionless Peer-to-peer Content Dissemination"
    :epilog [[
For more information, please visit our website:

    https://www.freechains.org/
]]

parser
    :flag("-v --version", "Show version.")
    :action(function()
        print("freechains " .. VERSION)
        os.exit(0)
    end)

parser
    :option("--root")
    :default(os.getenv("HOME") .. "/.freechains/")

local cmd = {
    chains = {
        _ = parser:command("chains")
    }
}
do  -- cmd.chains
    cmd.chains.add = {
        _ = cmd.chains._:command("add")
    }
    do  -- cmd.chains.add
        cmd.chains.add._:argument("alias")
        cmd.chains.add.lua = {
            _ = cmd.chains.add._:command("lua")
        }
        cmd.chains.add.lua._:argument("file")
    end

    cmd.chains.rem = {
        _ = cmd.chains._:command("rem")
    }
    do  -- cmd.chains.rem
        cmd.chains.rem._:argument("alias")
    end

    cmd.chains.dir = {
        _ = cmd.chains._:command("dir")
    }
end

local args = parser:parse()

if args.chains then
    local chains = args.root .. "/chains/"
    if args.add then
        if args.lua then
            local genesis = dofile(args.file)
            if type(genesis) ~= "table" then
                io.stderr:write("ERROR: file must return a table\n")
                os.exit(1)
            end

            local tmp = chains .. "/tmp-" .. os.time() .. "/"

            exec("git init " .. tmp)
            exec("cp " .. args.file .. " " .. tmp .. "/.genesis.lua")
            exec("git -C " .. tmp .. " add .genesis.lua")
            exec("git -C " .. tmp
                .. ' -c user.name="-" -c user.email="-"'
                .. ' commit --allow-empty-message -m ""')

            local hash = exec("git -C " .. tmp .. " rev-parse HEAD")

            local final = chains .. "/" .. hash
            os.rename(tmp, final)
            exec("ln -s " .. hash .. "/ " .. chains .. "/" .. args.alias)

            print(hash)
        end
    elseif args.rem then
        local alias = chains .. "/" .. args.alias
        local lnk = exec("readlink " .. alias)
        exec("rm -rf " .. chains .. lnk)
        os.remove(alias)
    elseif args.dir then
        local h = io.popen (
            "find " .. chains
            .. " -maxdepth 1 -type l -printf '%f\\n'"
            .. " 2>/dev/null | sort"
        )
        local out = h:read("a")
        h:close()
        if out ~= "" then
            io.write(out)
        end
    end
end
