#!/usr/bin/env lua5.4

local function die (msg)
    io.stderr:write("ERROR : chain send : " .. msg .. "\n")
    os.exit(1)
end

local line = io.read("l")
if io.read("l") then
    die "expected single branch"
end

local old, new, ref = line:match("(%S+) (%S+) (%S+)")
if ref ~= "refs/heads/main" then
    die "expected main branch"
end

local url
do
    local freechains
    local n = tonumber(os.getenv("GIT_PUSH_OPTION_COUNT") or "0") or 0
    for i=0, n-1 do
        local opt = os.getenv("GIT_PUSH_OPTION_" .. i) or ""
        if opt == "freechains=true" then
            freechains = true
        end
        local u = opt:match("^url=(.*)$")
        if u then
            url = u
        end
    end
    if not freechains then
        die "missing freechains push option"
    end
    if not url then
        die "missing url push option"
    end
end

local git_dir  = io.popen("cd " .. os.getenv("GIT_DIR") .. " && pwd"):read("l")
local repo_dir = git_dir:match("(.+)/[^/]+$")
local fc_root  = repo_dir:match("(.+)/[^/]+/[^/]+$")
local fc_chain = repo_dir:match("([^/]+)$")

local cmd = (
    "unset GIT_DIR GIT_QUARANTINE_PATH;" ..
        "freechains --root=" .. fc_root ..  " chain " .. fc_chain ..
        " sync recv " .. url ..  " 1>&2"
)
local ok = os.execute(cmd)
if not ok then
    os.exit(1)
end

io.stderr:write("Freechains: OK\n")
os.exit(1)
